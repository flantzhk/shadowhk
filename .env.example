# ShadowHK — Environment Variables
# Copy this file to .env.local and fill in your values

# Firebase Analytics (optional — get from Firebase console > Project settings)
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Admin dashboard access — set to the Firebase UID of the admin user
VITE_ADMIN_UID=

# PostHog product analytics (optional — get from app.posthog.com)
VITE_POSTHOG_KEY=
